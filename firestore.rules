rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Public read (storefront) ──────────────────
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /subcategories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /faqs/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /shipping/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Logged-in users only (admin) ──────────────
    match /coupons/{id} {
      allow read, write: if request.auth != null;
    }

    match /orders/{id} {
      allow read, write: if request.auth != null;
    }

    match /users/{id} {
      allow read, write: if request.auth != null;
    }

    match /admins/{id} {
      allow read, write: if request.auth != null;
    }

    match /notifications/{id} {
      allow read, write: if request.auth != null;
    }

    match /messages/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /customers/{id} {
      allow read, write: if request.auth != null;
    }

  }
}
